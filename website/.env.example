# ── Required ──────────────────────────────────────────────────────────────────

# Your Convex deployment's HTTP URL (Settings → URL & Deploy Key in Convex dashboard)
CONVEX_SITE_URL=https://your-project.convex.site

# Password for the /admin portal (must match the env var set in your Convex deployment)
ADMIN_SECRET=change-me-to-a-strong-secret

# ── Optional ──────────────────────────────────────────────────────────────────

# Canonical public URL (used for Open Graph / sitemap if you add them)
# NEXT_PUBLIC_URL=https://cardvault.app
